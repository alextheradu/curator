{
  "mcpServers": { 
    "tba": {
      "command": "bash",
      "args": [
        "-lc",
        "set -a; [ -f ./.env ] && . ./.env; [ -f ./.env.local ] && . ./.env.local; exec node scripts/tba-mcp-server.mjs"
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    }
  }
}
