{
  "name": "curator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "next dev -p 3001",
    "build": "rm -rf .next && node scripts/run-with-env.mjs .env next build && pm2 restart curator --update-env",
    "start": "node scripts/run-with-env.mjs .env node scripts/start-next.js",
    "site:check-assets": "node scripts/check-site-assets.mjs",
    "indexnow:submit": "node scripts/indexnow-submit.mjs",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "eval:chat": "node scripts/run-chat-evals.mjs",
    "db:migrate:dev": "node scripts/run-with-env.mjs .env.development.local drizzle-kit migrate",
    "db:studio:dev": "node scripts/run-with-env.mjs .env.development.local drizzle-kit studio",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios"
  },
  "browserslist": [
    "Chrome >= 109",
    "Firefox >= 115",
    "Safari >= 15.6",
    "Edge >= 109"
  ],
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@base-ui/react": "^1.4.0",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.49.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "minio": "^8.0.7",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
